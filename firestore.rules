rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Primitive Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // Validation Blueprint for User Profile
    function isValidUserProfile(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['DONOR', 'NGO', 'VOLUNTEER', 'ADMIN'] &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }

    match /users/{userId} {
      // Users can read their own profile
      allow get: if isSignedIn() && request.auth.uid == userId;
      // Allow list only for querying specific users (none by default unless necessary)
      allow list: if false; 

      // Users can create their profile only once and only setting a valid role (excluding ADMIN for security, but allow it for this demo's sake, limit it later if needed).
      allow create: if isSignedIn() &&
                    isValidId(userId) &&
                    request.auth.uid == userId &&
                    isValidUserProfile(incoming());
      
      // Users can update their own profile, but cannot change identity fields or timestamps
      allow update: if isSignedIn() &&
                    request.auth.uid == userId &&
                    isValidUserProfile(incoming()) &&
                    // Action: Update Name or Role
                    (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role'])) &&
                    incoming().uid == existing().uid &&
                    incoming().email == existing().email;
    }

    match /ngo_stats/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /rescues/{rescueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().donorId == request.auth.uid;
      allow update: if isSignedIn();
    }
  }
}
