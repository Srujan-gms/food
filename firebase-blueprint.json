{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a user, including their role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["DONOR", "NGO", "VOLUNTEER", "ADMIN"] },
        "name": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "role", "name", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles. Contains role information."
    }
  }
}
